# ============================================================
# ShowroomHub — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values

# --- Database (Required) ---
# Get from: https://neon.tech or your PostgreSQL provider
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# --- NextAuth (Required) ---
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
# Update this to your production domain in production
NEXTAUTH_URL=http://localhost:3000

# --- Admin Domain (Required) ---
# The main domain for your super admin dashboard
ADMIN_DOMAIN=showroomhub.com

# --- Vercel Blob Storage (Optional) ---
# Get from: Vercel Dashboard > Storage > Blob
# Used for image uploads
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx
