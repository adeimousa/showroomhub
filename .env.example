# ============================================================
# ShowroomHub — Environment Variables
# ============================================================
# Copy this file to `.env` (local dev) or set these in your
# hosting provider's dashboard (production).
# ============================================================

# --- Database ---
# LOCAL DEV (SQLite — works in sandbox + Docker + VPS):
DATABASE_URL=file:./db/custom.db

# VERCEL / SERVERLESS (Postgres — required because Vercel's filesystem is read-only):
# 1. Create a free Postgres DB at https://neon.tech or https://vercel.com/postgres
# 2. Set DATABASE_URL to the connection string they give you, e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/showroomhub?sslmode=require
# 3. Replace prisma/schema.prisma with prisma/schema.postgres.prisma:
#    cp prisma/schema.postgres.prisma prisma/schema.prisma
# 4. Run: bun run db:push && bun run scripts/seed.ts

# --- NextAuth ---
# Generate a new secret for production with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=6bvmAkb3px36aoyEdedcMB6FPh5pTExn+IIMGaPeLKQ=

# The public URL of your deployed site. Set this to your production domain:
# - Local dev:        http://localhost:3000
# - Vercel:           https://your-project.vercel.app
# - Custom domain:    https://showroomhub.com
NEXTAUTH_URL=http://localhost:3000
