// Prisma schema for Multi-Tenant Furniture SaaS Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // hashed in real apps; plaintext for demo
  name      String
  role      String   @default("CLIENT_ADMIN") // SUPER_ADMIN | CLIENT_ADMIN
  tenantId  String?  // null for super admins
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ============================================================
// TENANT (each furniture store)
// ============================================================

model Tenant {
  id              String   @id @default(cuid())
  name            String // public store name (English)
  nameAr          String? // Arabic
  nameHe          String? // Hebrew
  slug            String   @unique // used internally + for old preview URLs
  domain          String? // primary custom domain (kept for backward compat)
  customDomains   String   @default("[]") // JSON array of domains, e.g. ["velvetnight.com","www.velvetnight.com"]
  email           String
  phone           String?
  whatsappNumber  String? // E.164 without +, e.g. 15551234567 — used for cart checkout
  whatsappPrefill String? // optional custom intro line for the order message
  ownerName       String? // tenant owner name
  ownerEmail      String? // tenant owner email
  ownerPhone      String? // tenant owner phone
  validUntil      DateTime? // subscription expiry date
  description     String?
  descriptionAr   String?
  descriptionHe   String?
  status          String   @default("ACTIVE") // ACTIVE | PAUSED | SUSPENDED
  plan            String   @default("BASIC") // BASIC | PRO | PREMIUM
  layoutId        String? // assigned layout
  themePrimary    String   @default("#0f766e") // teal-700
  themeAccent     String   @default("#f59e0b") // amber-500
  themeBg         String   @default("#ffffff")
  themeFont       String   @default("Inter")
  rtl             Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  layout    Layout?     @relation(fields: [layoutId], references: [id])
  users     User[]
  products  Product[]
  categories Category[]
  heroSlides HeroSlide[]
  payments  Payment[]
}

// ============================================================
// LAYOUT (30 unique site layouts)
// ============================================================

model Layout {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String // MODERN | LUXURY | MINIMAL | CREATIVE | CLASSIC
  description String
  premium     Boolean  @default(false)
  // Style tokens used by the renderer
  headerStyle   String // e.g. "minimal-bar", "centered-logo", "split-nav"
  heroStyle     String // e.g. "split-image", "full-bleed", "carousel", "grid-cells"
  productGrid   String // e.g. "3-col-cards", "4-col-tight", "masonry", "list-rows"
  footerStyle   String // e.g. "footer-minimal", "footer-mega", "footer-center"
  primaryColor  String
  accentColor   String
  bgColor       String
  textColor     String
  fontHeading   String
  fontBody      String
  borderRadius  Int      @default(8) // px
  animation     String   @default("fade") // fade | slide | zoom | none
  createdAt     DateTime @default(now())

  tenants Tenant[]
}

// ============================================================
// CATALOG
// ============================================================

model Category {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  nameAr    String?
  nameHe    String?
  icon      String? // emoji or lucide name
  createdAt DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  categoryId  String?
  name        String
  nameAr      String?
  nameHe      String?
  description String?
  descriptionAr String?
  descriptionHe String?
  price       Float
  compareAt   Float? // original price for discount display
  sku         String?
  stock       Int      @default(0)
  image       String? // URL or emoji placeholder
  featured    Boolean  @default(false)
  status      String   @default("ACTIVE") // ACTIVE | DRAFT | ARCHIVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])
}

model HeroSlide {
  id        String   @id @default(cuid())
  tenantId  String
  title     String
  titleAr   String?
  titleHe   String?
  subtitle  String?
  subtitleAr String?
  subtitleHe String?
  image     String? // emoji or color
  ctaText   String   @default("Shop Now")
  ctaLink   String   @default("#")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ============================================================
// PAYMENTS (manual tracking)
// ============================================================

model Payment {
  id          String   @id @default(cuid())
  tenantId    String
  amount      Float
  currency    String   @default("USD")
  period      String // e.g. "2026" yearly
  status      String   @default("PENDING") // PENDING | PAID | OVERDUE
  method      String? // BANK | CARD | PAYPAL
  invoiceNo   String?
  paidAt      DateTime?
  dueDate     DateTime?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
